{
  "mcpServers": {
    "ruflo": {
      "type": "stdio",
      "command": "ruflo",
      "args": [
        "mcp",
        "start"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "magicuidesign": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@magicuidesign/mcp@latest"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    }
  }
}